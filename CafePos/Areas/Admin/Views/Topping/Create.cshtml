@model CafePos.Models.Topping
@{
    ViewData["Title"] = "Thêm mới topping";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-lg border-0 rounded-3 mt-4">
            <div class="card-header bg-primary text-white py-3">
                <h5 class="mb-0 fw-bold">
                    <i class="bi bi-plus-circle-fill me-2"></i>Thêm Topping Mới
                </h5>
            </div>

            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="form-group mb-4">
                        <label asp-for="Name" class="form-label fw-bold text-secondary">Tên topping</label>
                        <input asp-for="Name" class="form-control form-control-lg border-2"
                               placeholder="VD: Trân châu, Sữa tươi, Thạch..." autofocus />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Price" class="form-label fw-bold text-secondary">Giá thêm</label>
                        <input asp-for="Price" type="number" class="form-control form-control-lg border-2"
                               placeholder="VD: 10000" min="0" step="1000" />
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                        <label asp-for="IsActive" class="form-check-label fw-bold text-secondary">
                            Kích hoạt ngay
                        </label>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">Quay lại</a>
                        <button type="submit" class="btn btn-primary px-5 shadow">Lưu topping</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="alert alert-info mt-4 border-0 shadow-sm">
            <small>
                <i class="bi bi-info-circle-fill me-1"></i>
                Mẹo: Nên đặt giá topping theo bước 1.000đ để dễ hiển thị và tính tiền trên POS.
            </small>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}