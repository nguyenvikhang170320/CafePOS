@model CafePos.Models.User

@{
    ViewData["Title"] = "Chi tiết tài khoản";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-info text-white">
            <h3 class="mb-0"><i class="bi bi-person-gear"></i> Chi tiết tài khoản</h3>
        </div>

        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Tên tài khoản</dt>
                <dd class="col-sm-9">@Model.Username</dd>

                <dt class="col-sm-3">Họ và tên</dt>
                <dd class="col-sm-9">@Model.FullName</dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.Email</dd>

                <dt class="col-sm-3">Loại tài khoản</dt>
                <dd class="col-sm-9">@Model.Role?.Name</dd>

                <dt class="col-sm-3">Trạng thái</dt>
                <dd class="col-sm-9">@Model.TrangThai</dd>

                <dt class="col-sm-3">Ngày cập nhật</dt>
                <dd class="col-sm-9">@Model.NgayCapNhat.ToString("dd/MM/yyyy HH:mm")</dd>
            </dl>
        </div>

        <div class="card-footer text-end">
            <a asp-action="Edit" asp-route-id="@Model.UserId" class="btn btn-warning me-2">
                <i class="bi bi-pencil-square"></i> Sửa
            </a>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>
    </div>
</div>