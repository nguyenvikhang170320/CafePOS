@using X.PagedList
@using X.PagedList.Mvc.Core
@model IPagedList<CafePos.Models.User>

@{
    ViewData["Title"] = "Danh sách tài khoản";
    var currentFilter = ViewData["CurrentFilter"] as string;
    bool showDeleted = ViewBag.ShowDeleted == true;
    bool isAdmin = User.IsInRole("Admin");
}

<div class="container-fluid px-4 mt-3">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
</div>

<div class="container-fluid px-4">
    <div class="card shadow mb-4 border-0">
        <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between bg-white">
            <h5 class="m-0 fw-bold text-primary">
                <i class="bi bi-person-gear me-2"></i>Danh sách tài khoản
            </h5>

            <div>
                @if (isAdmin)
                {
                    if (showDeleted)
                    {
                        <a asp-action="Index" asp-route-showDeleted="false" class="btn btn-sm btn-secondary shadow-sm me-2">
                            <i class="bi bi-arrow-left-circle"></i> Quay lại danh sách
                        </a>
                    }
                    else
                    {
                        <a asp-action="Index" asp-route-showDeleted="true" class="btn btn-sm btn-warning shadow-sm me-2">
                            <i class="bi bi-trash"></i> Thùng rác
                        </a>
                    }

                    @if (!showDeleted)
                    {
                        <a asp-action="Create" class="btn btn-sm btn-success shadow-sm">
                            <i class="bi bi-person-plus-fill"></i> Thêm tài khoản
                        </a>
                    }
                }
            </div>
        </div>

        <div class="card-body">
            <form asp-action="Index" method="get" class="mb-4 col-md-8 col-lg-6">
                <input type="hidden" name="showDeleted" value="@showDeleted" />

                <div class="input-group">
                    <span class="input-group-text bg-white text-muted">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text" name="searchString" class="form-control bg-light border-0 small"
                           placeholder="Tìm theo tên tài khoản, họ tên, email..."
                           value="@currentFilter" />

                    <button class="btn btn-primary" type="submit">
                        <i class="bi bi-search"></i> Tìm kiếm
                    </button>

                    @if (!string.IsNullOrEmpty(currentFilter))
                    {
                        <a asp-action="Index" asp-route-showDeleted="@showDeleted" class="btn btn-secondary" title="Làm mới">
                            <i class="bi bi-arrow-counterclockwise"></i>
                        </a>
                    }
                </div>
            </form>

            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle" width="100%" cellspacing="0">
                    <thead class="table-light text-dark text-nowrap">
                        <tr>
                            <th class="text-center" style="width: 70px;">Mã</th>
                            <th>Tên đăng nhập</th>
                            <th>Họ và tên</th>
                            <th>Email</th>
                            <th class="text-center">Loại tài khoản</th>
                            <th class="text-center">Trạng thái</th>
                            <th>Ngày cập nhật</th>
                            <th class="text-center" style="width: 180px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center fw-bold text-secondary">@item.UserId</td>
                                    <td class="fw-bold text-primary">@item.Username</td>
                                    <td>@item.FullName</td>
                                    <td>@item.Email</td>

                                    <td class="text-center">
                                        @if (item.Role != null && item.Role.Name == "Admin")
                                        {
                                            <span class="badge bg-danger rounded-pill">Admin</span>
                                        }
                                        else if (item.Role != null && item.Role.Name == "Staff")
                                        {
                                            <span class="badge bg-primary rounded-pill">Staff</span>
                                        }
                                        else if (item.Role != null && item.Role.Name == "Employee")
                                        {
                                            <span class="badge bg-success rounded-pill">Employee</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary rounded-pill">Không rõ</span>
                                        }
                                    </td>

                                    <td class="text-center">
                                        @if (item.TrangThai == "Hoạt động")
                                        {
                                            <span class="badge bg-success rounded-pill">Hoạt động</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark rounded-pill">@item.TrangThai</span>
                                        }
                                    </td>

                                    <td>
                                        @item.NgayCapNhat.ToString("dd/MM/yyyy HH:mm")
                                    </td>

                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm shadow-sm" role="group">
                                            @if (showDeleted)
                                            {
                                                @if (isAdmin)
                                                {
                                                    <a asp-action="Restore" asp-route-id="@item.UserId"
                                                       class="btn btn-success"
                                                       onclick="return confirm('Khôi phục tài khoản @item.Username?');"
                                                       data-bs-toggle="tooltip" title="Khôi phục">
                                                        <i class="bi bi-arrow-counterclockwise"></i>
                                                    </a>
                                                }
                                            }
                                            else
                                            {
                                                <a asp-action="Details" asp-route-id="@item.UserId"
                                                   class="btn btn-outline-info"
                                                   data-bs-toggle="tooltip" title="Xem chi tiết">
                                                    <i class="bi bi-eye-fill"></i>
                                                </a>

                                                <a asp-action="ChangePassword" asp-route-id="@item.UserId"
                                                   class="btn btn-outline-secondary"
                                                   data-bs-toggle="tooltip" title="Đổi mật khẩu">
                                                    <i class="bi bi-key-fill"></i>
                                                </a>

                                                @if (isAdmin)
                                                {
                                                    <a asp-action="Edit" asp-route-id="@item.UserId"
                                                       class="btn btn-outline-warning"
                                                       data-bs-toggle="tooltip" title="Chỉnh sửa">
                                                        <i class="bi bi-pencil-square"></i>
                                                    </a>

                                                    <a asp-action="Delete" asp-route-id="@item.UserId"
                                                       class="btn btn-outline-danger"
                                                       onclick="return confirm('Bạn có chắc muốn xóa tài khoản @item.Username không?');"
                                                       data-bs-toggle="tooltip" title="Xóa">
                                                        <i class="bi bi-trash-fill"></i>
                                                    </a>
                                                }
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center py-4 text-muted">
                                    <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                                    Không tìm thấy tài khoản nào phù hợp.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="row mt-3">
                <div class="col-md-6 pt-2">
                    Hiển thị trang <b>@(Model.PageCount < Model.PageNumber ? 0 : Model.PageNumber)</b> / <b>@Model.PageCount</b>
                </div>
                <div class="col-md-6">
                    <div class="float-end">
                        @Html.PagedListPager(
                        Model,
                        page => Url.Action("Index", new
                        {
                            page,
                            searchString = currentFilter,
                            showDeleted = showDeleted
                        }),
                                                new PagedListRenderOptions
                                                {
                                                    LiElementClasses = new[] { "page-item" },
                                                    PageClasses = new[] { "page-link" },
                                                    MaximumPageNumbersToDisplay = 5,
                                                    DisplayEllipsesWhenNotShowingAllPageNumbers = true,
                                                    EllipsesFormat = "...",
                                                    DisplayLinkToFirstPage = PagedListDisplayMode.Always,
                                                    DisplayLinkToLastPage = PagedListDisplayMode.Always,
                                                    DisplayLinkToPreviousPage = PagedListDisplayMode.Always,
                                                    DisplayLinkToNextPage = PagedListDisplayMode.Always,
                                                    LinkToFirstPageFormat = "Trang đầu",
                                                    LinkToPreviousPageFormat = "«",
                                                    LinkToNextPageFormat = "»",
                                                    LinkToLastPageFormat = "Trang cuối",
                                                    ActiveLiElementClass = "active"
                                                })
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl);
        });
    </script>
}