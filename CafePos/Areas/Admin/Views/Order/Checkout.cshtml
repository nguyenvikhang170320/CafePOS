@model Order
@using CafePos.Models

@{
    ViewData["Title"] = "Checkout";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var toppings = ViewBag.Toppings as List<Topping>;
}

<div class="container-fluid py-4">
    <div class="mb-4">
        <h3 class="fw-bold mb-1">Checkout đơn hàng</h3>
        <p class="text-muted mb-0">Xác nhận thanh toán, thêm topping nếu khách yêu cầu và tính lại tổng tiền.</p>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-success text-white rounded-top-4">
                    <h5 class="mb-0">Chi tiết thanh toán</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-4">
                                <div class="small text-muted">Mã đơn</div>
                                <div class="fw-semibold">@Model.OrderCode</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-4">
                                <div class="small text-muted">Ngày tạo</div>
                                <div class="fw-semibold">@Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-4">
                                <div class="small text-muted">Khách hàng</div>
                                <div class="fw-semibold">@Model.CustomerName</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-4">
                                <div class="small text-muted">Số điện thoại</div>
                                <div class="fw-semibold">@Model.CustomerPhone</div>
                            </div>
                        </div>
                    </div>

                    <div class="table-responsive mb-4">
                        <table class="table align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Món</th>
                                    <th class="text-center">SL</th>
                                    <th class="text-end">Đơn giá</th>
                                    <th class="text-end">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.OrderItems != null && Model.OrderItems.Any())
                                {
                                    foreach (var item in Model.OrderItems)
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-semibold">@item.ProductNameSnapshot</div>

                                                @if (!string.IsNullOrEmpty(item.SizeNameSnapshot))
                                                {
                                                    <div class="small text-muted">Size: @item.SizeNameSnapshot</div>
                                                }

                                                @if (item.OrderItemToppings != null && item.OrderItemToppings.Any())
                                                {
                                                    <div class="small text-muted mt-1">
                                                        Topping hiện có:
                                                        @string.Join(", ", item.OrderItemToppings.Select(x => x.ToppingNameSnapshot))
                                                    </div>
                                                }
                                            </td>
                                            <td class="text-center">@item.Quantity</td>
                                            <td class="text-end">@item.UnitPrice.ToString("N0") đ</td>
                                            <td class="text-end fw-semibold text-danger">@item.LineTotal.ToString("N0") đ</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center text-muted py-4">Chưa có món trong đơn.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <form asp-controller="Order" asp-action="Checkout" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.OrderId" />

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Thêm topping nếu khách yêu cầu</label>
                            <div class="row">
                                @if (toppings != null && toppings.Any())
                                {
                                    foreach (var t in toppings)
                                    {
                                        var checkedTopping = Model.OrderItems != null
                                        && Model.OrderItems.Any(i => i.OrderItemToppings != null
                                        && i.OrderItemToppings.Any(top => top.ToppingId == t.ToppingId));

                                        <div class="col-md-6 mb-2">
                                            <div class="form-check border rounded-3 p-2">
                                                <input class="form-check-input topping-check"
                                                       type="checkbox"
                                                       name="selectedToppingIds"
                                                       value="@t.ToppingId"
                                                       data-price="@t.Price"
                                                       id="top_@t.ToppingId"
                                                       @(checkedTopping ? "checked" : null) />
                                                <label class="form-check-label ms-2" for="top_@t.ToppingId">
                                                    @t.Name (+@t.Price.ToString("N0") đ)
                                                </label>
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="text-muted">Hiện chưa có topping nào.</div>
                                }
                            </div>
                        </div>

                        <div class="row g-4 align-items-end">
                            <div class="col-md-6">
                                <label class="form-label">Phương thức thanh toán</label>
                                <select name="paymentMethod" class="form-select rounded-3" required>
                                    <option value="">-- Chọn phương thức --</option>
                                    <option value="Cash" selected="@(Model.PaymentMethod == "Cash")">Tiền mặt</option>
                                    <option value="Banking" selected="@(Model.PaymentMethod == "Banking")">Chuyển khoản</option>
                                    <option value="Card" selected="@(Model.PaymentMethod == "Card")">Thẻ</option>
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Giảm giá</label>
                                <input type="number"
                                       step="0.01"
                                       min="0"
                                       name="discountAmount"
                                       id="discountAmount"
                                       class="form-control rounded-3"
                                       value="@Model.DiscountAmount" />
                            </div>

                            <div class="col-12">
                                <div class="p-3 border rounded-4 bg-light">
                                    <div class="d-flex justify-content-between mb-2">
                                        <span>Tạm tính</span>
                                        <strong id="showSubTotal">@Model.SubTotal.ToString("N0") đ</strong>
                                    </div>
                                    <div class="d-flex justify-content-between mb-2">
                                        <span>Giảm giá</span>
                                        <strong id="showDiscount">@Model.DiscountAmount.ToString("N0") đ</strong>
                                    </div>
                                    <div class="d-flex justify-content-between pt-2 border-top">
                                        <span class="fw-bold">Tổng tiền</span>
                                        <span id="showTotal" class="fw-bold text-danger fs-5">@Model.TotalAmount.ToString("N0") đ</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mt-4 d-flex gap-2">
                            @if (Model.PaymentStatus == "Paid" || Model.OrderStatus == "Completed")
                            {
                                <button type="button" class="btn btn-secondary rounded-pill px-4" disabled>
                                    Đơn đã thanh toán
                                </button>
                            }
                            else
                            {
                                <button type="submit" class="btn btn-success rounded-pill px-4">
                                    Xác nhận thanh toán
                                </button>
                            }

                            <a asp-controller="Order"
                               asp-action="Detail"
                               asp-route-id="@Model.OrderId"
                               class="btn btn-outline-secondary rounded-pill px-4">
                                Xem chi tiết
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <h5 class="fw-bold mb-3">Luồng xử lý</h5>
                    <div class="d-flex flex-column gap-3">
                        <div class="p-3 bg-light rounded-4">
                            <strong>Bước 1:</strong> Kiểm tra lại món khách đã đặt
                        </div>
                        <div class="p-3 bg-light rounded-4">
                            <strong>Bước 2:</strong> Thêm topping nếu khách yêu cầu
                        </div>
                        <div class="p-3 bg-light rounded-4">
                            <strong>Bước 3:</strong> Chọn thanh toán và hoàn tất đơn
                        </div>
                    </div>

                    <hr />

                    <p class="text-muted mb-0">
                        Nếu đơn đã thanh toán rồi thì nút thanh toán sẽ bị khóa để tránh thanh toán lặp.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function formatMoney(value) {
            return new Intl.NumberFormat('vi-VN').format(value) + ' đ';
        }

        function calculateCheckoutTotal() {
            let baseSubTotal = parseFloat('@Model.SubTotal'.replace(',', '.')) || 0;
            let discount = parseFloat(document.getElementById('discountAmount').value || 0);

            let existingToppingIds = [];
            @if (Model.OrderItems != null)
            {
               foreach (var item in Model.OrderItems)
               {
                 if (item.OrderItemToppings != null)
                 {
                    foreach (var top in item.OrderItemToppings)
                    {
                      @:existingToppingIds.push(@top.ToppingId);
                    }
                 }
               }
            }

            let addedToppingTotal = 0;

            document.querySelectorAll('.topping-check:checked').forEach(function (cb) {
                let toppingId = parseInt(cb.value);
                let price = parseFloat(cb.dataset.price || 0);

                if (!existingToppingIds.includes(toppingId)) {
                    addedToppingTotal += price;
                }
            });

            let newSubTotal = baseSubTotal + addedToppingTotal;
            let newTotal = newSubTotal - discount;

            if (newTotal < 0) newTotal = 0;

            document.getElementById('showSubTotal').innerText = formatMoney(newSubTotal);
            document.getElementById('showDiscount').innerText = formatMoney(discount);
            document.getElementById('showTotal').innerText = formatMoney(newTotal);
        }

        document.addEventListener('DOMContentLoaded', function () {
            const discountInput = document.getElementById('discountAmount');
            if (discountInput) {
                discountInput.addEventListener('input', calculateCheckoutTotal);
            }

            document.querySelectorAll('.topping-check').forEach(function (checkbox) {
                checkbox.addEventListener('change', calculateCheckoutTotal);
            });

            calculateCheckoutTotal();
        });
    </script>
}