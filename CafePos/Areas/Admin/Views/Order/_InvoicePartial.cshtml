@model Order

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-primary text-white rounded-top-4 d-flex justify-content-between align-items-center">
        <div>
            <h5 class="mb-1 fw-bold">Hóa đơn: @Model.OrderCode</h5>
            <div class="small">Ngày tạo: @Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")</div>
        </div>
        <div class="d-flex gap-2">
            <a 
               asp-controller="Order"
               asp-action="PrintInvoice"
               asp-route-id="@Model.OrderId"
               target="_blank"
               class="btn btn-light btn-sm rounded-pill px-3">
                In hóa đơn
            </a>
            <a 
               asp-controller="Order"
               asp-action="Checkout"
               asp-route-id="@Model.OrderId"
               class="btn btn-warning btn-sm rounded-pill px-3">
                Checkout
            </a>
        </div>
    </div>

    <div class="card-body">
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="p-3 bg-light rounded-4 h-100">
                    <div class="small text-muted">Khách hàng</div>
                    <div class="fw-semibold">@Model.CustomerName</div>

                    <div class="small text-muted mt-2">Số điện thoại</div>
                    <div class="fw-semibold">@Model.CustomerPhone</div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="p-3 bg-light rounded-4 h-100">
                    <div class="small text-muted">Trạng thái đơn</div>
                    <div class="fw-semibold">
                        @if (Model.OrderStatus == "Completed")
                        {
                            <span class="badge bg-success">Hoàn thành</span>
                        }
                        else if (Model.OrderStatus == "Pending")
                        {
                            <span class="badge bg-warning text-dark">Chờ xử lý</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@(Model.OrderStatus == "Cancelled" ? "Đã hủy" : Model.OrderStatus)</span>
                        }
                    </div>

                    <div class="small text-muted mt-2">Thanh toán</div>
                    <div class="fw-semibold">
                        @if (Model.PaymentStatus == "Paid")
                        {
                            <span class="badge bg-success">Đã thành toán</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Chưa thanh toán</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Món</th>
                        <th class="text-center">SL</th>
                        <th class="text-end">Đơn giá</th>
                        <th>Topping</th>
                        <th class="text-end">Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.OrderItems != null && Model.OrderItems.Any())
                    {
                        foreach (var item in Model.OrderItems)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@item.ProductNameSnapshot</div>

                                    @if (!string.IsNullOrEmpty(item.SizeNameSnapshot))
                                    {
                                        <div class="small text-muted">Size: @item.SizeNameSnapshot</div>
                                    }

                                    @if (!string.IsNullOrEmpty(item.ItemNote))
                                    {
                                        <div class="small text-muted">Ghi chú: @item.ItemNote</div>
                                    }
                                </td>
                                <td class="text-center">@item.Quantity</td>
                                <td class="text-end">@item.UnitPrice.ToString("N0") đ</td>
                                <td>
                                    @if (item.OrderItemToppings != null && item.OrderItemToppings.Any())
                                    {
                                        <div class="d-flex flex-column gap-1">
                                            @foreach (var top in item.OrderItemToppings)
                                            {
                                                <span class="badge bg-light text-dark border text-start">
                                                    @top.ToppingNameSnapshot x @top.Quantity
                                                    (+@top.TotalPrice.ToString("N0") đ)
                                                </span>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Không có</span>
                                    }
                                </td>
                                <td class="text-end fw-semibold text-danger">@item.LineTotal.ToString("N0") đ</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">Không có món trong đơn.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="row mt-4">
            <div class="col-md-6">
                @if (!string.IsNullOrEmpty(Model.Note))
                {
                    <div class="p-3 bg-light rounded-4">
                        <div class="fw-semibold mb-1">Ghi chú đơn hàng</div>
                        <div class="text-muted">@Model.Note</div>
                    </div>
                }
            </div>

            <div class="col-md-6">
                <div class="p-3 border rounded-4 bg-white">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Tạm tính</span>
                        <span>@Model.SubTotal.ToString("N0") đ</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Giảm giá</span>
                        <span>@Model.DiscountAmount.ToString("N0") đ</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between">
                        <span class="fw-bold">Tổng tiền</span>
                        <span class="fw-bold text-danger fs-5">@Model.TotalAmount.ToString("N0") đ</span>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.PaymentStatus != "Paid")
        {
            <div class="text-end mt-4">
                <button class="btn btn-success rounded-pill px-4 btn-mark-paid"
                        data-id="@Model.OrderId"
                        data-method="Cash">
                    Thanh toán tiền mặt
                </button>

                <button class="btn btn-outline-primary rounded-pill px-4 btn-mark-paid"
                        data-id="@Model.OrderId"
                        data-method="Banking">
                    Thanh toán chuyển khoản
                </button>
            </div>
        }
    </div>
</div>

<script>
    $(".btn-mark-paid").click(function () {
        let id = $(this).data("id");
        let method = $(this).data("method");

        $.ajax({
            url: '@Url.Action("MarkAsPaid", "Orders", new { area = "Admin" })',
            type: 'POST',
            data: { id: id, paymentMethod: method },
            success: function (res) {
                if (res.success) {
                    $.get('@Url.Action("GetInvoicePartial", "Orders", new { area = "Admin" })',
                        { id: id },
                        function (html) {
                            $("#invoiceDetail").html(html);
                        });
                } else {
                    alert(res.message);
                }
            },
            error: function () {
                alert("Có lỗi xảy ra khi thanh toán.");
            }
        });
    });
</script>