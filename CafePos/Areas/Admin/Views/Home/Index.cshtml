@{
    ViewData["Title"] = "Bảng điều khiển";
}

<div class="text-center mb-5 mt-4">
    <h1 class="display-5 fw-bold text-dark">Chào mừng đến với Bảng Điều Khiển</h1>
    <p class="text-muted fs-5">Quản lý tổng quan hoạt động kinh doanh quán cafe của bạn.</p>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card h-100 shadow-sm border-0 rounded-3">
            <div class="card-body text-center p-4">
                <div class="display-4 text-primary mb-3">🍔</div>
                <h4 class="card-title fw-bold">Quản lý Thực Đơn 111</h4>
                <p class="card-text text-muted">Thêm, sửa, xóa các loại nước uống, thức ăn, topping và thiết lập giá bán.</p>
                <a href="#" class="btn btn-outline-primary px-4 rounded-pill">Truy cập Menu</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100 shadow-sm border-0 rounded-3">
            <div class="card-body text-center p-4">
                <div class="display-4 text-success mb-3">🛒</div>
                <h4 class="card-title fw-bold">Đơn Hàng Hôm Nay</h4>
                <p class="card-text text-muted">Theo dõi và cập nhật trạng thái đơn hàng (Đang pha chế, Hoàn tất) từ App.</p>
                <a href="#" class="btn btn-outline-success px-4 rounded-pill">Xem Đơn Hàng</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100 shadow-sm border-0 rounded-3">
            <div class="card-body text-center p-4">
                <div class="display-4 text-warning mb-3">📈</div>
                <h4 class="card-title fw-bold">Báo Cáo Doanh Thu</h4>
                <p class="card-text text-muted">Kiểm tra doanh thu trong ngày, xem danh sách các món bán chạy nhất.</p>
                <a href="#" class="btn btn-outline-warning px-4 rounded-pill">Xem Báo Cáo</a>
            </div>
        </div>
    </div>
</div>