@model IEnumerable<CafePos.Models.Product>
@{
    ViewData["Title"] = "Thùng rác sản phẩm";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="text-secondary fw-bold mb-0">
                <i class="bi bi-trash3-fill me-2"></i>Thùng rác sản phẩm
            </h3>
            <p class="text-muted small mb-0">Danh sách các món đã tạm ẩn khỏi thực đơn</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-primary shadow-sm bg-white">
            <i class="bi bi-arrow-left"></i> Quay lại danh sách
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3" style="width: 100px;">Ảnh</th>
                            <th>Tên sản phẩm</th>
                            <th>Loại</th>
                            <th class="text-center">Giá cũ</th>
                            <th class="text-end pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox display-4 d-block mb-2"></i>
                                    Thùng rác đang trống.
                                </td>
                            </tr>
                        }
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <img src="@item.ImageUrl" class="rounded shadow-sm" style="width: 50px; height: 50px; object-fit: cover;" />
                                </td>
                                <td>
                                    <span class="fw-bold text-dark">@item.Name</span>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border">@(item.Category?.Name ?? "N/A")</span>
                                </td>
                                <td class="text-center">
                                    @item.BasePrice.ToString("N0")đ
                                </td>
                                <td class="text-end pe-4">
                                    <form asp-action="Restore" asp-route-id="@item.ProductId" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-success px-3 shadow-sm">
                                            <i class="bi bi-arrow-counterclockwise"></i> Khôi phục
                                        </button>
                                    </form>

                                    @* Nếu bạn muốn thêm nút Xóa vĩnh viễn (Hard Delete) thì thêm ở đây *@
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>