@model CafePos.Models.Product
@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<div class="container py-4">
    <div class="card shadow-lg border-0 rounded-3 overflow-hidden">
        <div class="card-header bg-info text-white py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-info-circle-fill me-2"></i>Thông tin món: @Model.Name</h5>
        </div>
        <div class="card-body p-4">
            <div class="row align-items-center">
                <div class="col-md-4 text-center mb-4 mb-md-0">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" class="img-fluid rounded-3 shadow-sm border" style="max-height: 300px; object-fit: cover;" alt="@Model.Name" />
                    }
                    else
                    {
                        <div class="bg-light rounded-3 d-flex align-items-center justify-content-center border" style="height: 250px;">
                            <i class="bi bi-image text-muted display-1"></i>
                        </div>
                    }
                </div>

                <div class="col-md-8">
                    <div class="ps-md-4">
                        <h2 class="text-dark fw-bold mb-1">@Model.Name</h2>
                        <span class="badge bg-light text-secondary border mb-4">
                            <i class="bi bi-tag-fill me-1"></i> @(Model.Category?.Name ?? "Chưa phân loại")
                        </span>

                        <div class="row g-3">
                            <div class="col-6">
                                <label class="text-muted small d-block">Giá bán hiện tại</label>
                                <span class="fs-3 fw-bold text-primary">@Model.BasePrice.ToString("N0") <small>VNĐ</small></span>
                            </div>
                            <div class="col-6">
                                <label class="text-muted small d-block">Trạng thái</label>
                                @if (Model.IsActive)
                                {
                                    <span class="text-success fw-bold"><i class="bi bi-check-circle-fill"></i> Đang kinh doanh</span>
                                }
                                else
                                {
                                    <span class="text-danger fw-bold"><i class="bi bi-x-circle-fill"></i> Đang tạm dừng</span>
                                }
                            </div>
                        </div>

                        <hr class="my-4" />

                        <div class="d-flex gap-2">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                                <i class="bi bi-arrow-left"></i> Quay lại
                            </a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@Model.ProductId" class="btn btn-warning px-4">
                                    <i class="bi bi-pencil-square"></i> Chỉnh sửa món
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>