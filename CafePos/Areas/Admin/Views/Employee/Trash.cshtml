@model IEnumerable<CafePos.Models.Employee>
@{
    ViewData["Title"] = "Thùng rác nhân viên";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="text-secondary fw-bold mb-0">
                <i class="bi bi-trash3-fill me-2"></i>Thùng rác nhân viên
            </h3>
            <p class="text-muted small mb-0">Danh sách nhân viên đã tạm khóa hoặc nghỉ việc</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-primary shadow-sm bg-white">
            <i class="bi bi-arrow-left"></i> Quay lại danh sách
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3" style="width: 100px;">Ảnh</th>
                            <th>Mã NV</th>
                            <th>Họ Tên</th>
                            <th>Tài khoản</th>
                            <th>Số điện thoại</th>
                            <th class="text-end pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-person-x display-4 d-block mb-2"></i>
                                    Thùng rác đang trống.
                                </td>
                            </tr>
                        }
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" class="rounded-circle shadow-sm" style="width: 45px; height: 45px; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <img src="/images/default-avatar.png" class="rounded-circle shadow-sm" style="width: 45px; height: 45px;" />
                                    }
                                </td>
                                <td>
                                    <span class="fw-bold">@item.EmployeeCode</span>
                                </td>
                                <td>
                                    <div class="text-dark">@item.User.FullName</div>
                                </td>
                                <td>
                                    <span class="badge bg-light text-primary border">@item.User.Username</span>
                                </td>
                                <td>
                                    @item.PhoneNumber
                                </td>
                                <td class="text-end pe-4">
                                    <form asp-action="Restore" asp-route-id="@item.EmployeeId" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-success px-3 shadow-sm">
                                            <i class="bi bi-arrow-counterclockwise"></i> Khôi phục
                                        </button>
                                    </form>

                                    @* Nút xóa vĩnh viễn (nếu cần) *@
                                    @* <a asp-action="DeletePermanent" asp-route-id="@item.UserId" class="btn btn-sm btn-outline-danger ms-1">Xóa hẳn</a> *@
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>