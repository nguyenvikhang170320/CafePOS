@model CafePos.Models.ViewModels.EmployeeVM
@{
    ViewData["Title"] = "Thêm nhân viên mới";
}

<div class="row justify-content-center py-4">
    <div class="col-md-10 col-lg-8">
        <div class="card shadow-lg border-0 rounded-3">
            <div class="card-header bg-primary text-white py-3 text-center">
                <h4 class="mb-0 fw-bold">
                    <i class="bi bi-person-plus-fill me-2"></i>Thêm Nhân Viên Mới
                </h4>
            </div>

            <div class="card-body p-4">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <h5 class="text-secondary border-bottom pb-2 mb-3">Thông tin tài khoản</h5>

                    <div class="form-group mb-3">
                        <label asp-for="UserId" class="form-label fw-bold">Chọn tài khoản nhân viên</label>
                        <select asp-for="UserId" class="form-select border-2" asp-items="ViewBag.UserId">
                            <option value="">-- Chọn tài khoản chưa tạo nhân viên --</option>
                        </select>
                        <span asp-validation-for="UserId" class="text-danger small"></span>
                    </div>

                    <h5 class="text-secondary border-bottom pb-2 mt-3 mb-3">Thông tin cá nhân</h5>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="EmployeeCode" class="form-label fw-bold">Mã nhân viên (Tùy chọn)</label>
                                <input asp-for="EmployeeCode" class="form-control border-2" placeholder="VD: NV001" />
                                <span asp-validation-for="EmployeeCode" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="PhoneNumber" class="form-label fw-bold">Số điện thoại</label>
                                <input asp-for="PhoneNumber" class="form-control border-2" placeholder="VD: 090xxxxxxx" />
                                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Address" class="form-label fw-bold">Địa chỉ</label>
                        <input asp-for="Address" class="form-control border-2" placeholder="Nhập địa chỉ tạm trú" />
                        <span asp-validation-for="Address" class="text-danger small"></span>
                    </div>

                    <h5 class="text-secondary border-bottom pb-2 mt-3 mb-3">Ảnh hồ sơ</h5>

                    <div class="form-group mb-3">
                        <label class="form-label fw-bold">Cách 1: Chọn ảnh từ máy</label>
                        <input type="file" name="file" class="form-control border-2" id="fileInput" accept="image/*" />
                    </div>

                    <div class="text-center text-muted small mb-2">Hoặc</div>

                    <div class="form-group mb-3">
                        <label asp-for="ImageUrl" class="form-label fw-bold">Cách 2: Dán URL ảnh</label>
                        <input asp-for="ImageUrl" class="form-control border-2" id="urlInput"
                               placeholder="https://example.com/avatar.jpg" />
                        <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                    </div>

                    <div class="text-center mb-3">
                        <img id="imgPreview"
                             src="@(string.IsNullOrWhiteSpace(Model?.ImageUrl) ? "#" : Model.ImageUrl)"
                             alt="Xem trước ảnh"
                             class="rounded-circle shadow-sm @(string.IsNullOrWhiteSpace(Model?.ImageUrl) ? "d-none" : "")"
                             style="width: 150px; height: 150px; object-fit: cover; border: 3px solid #eee;" />
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end pt-3">
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">Hủy bỏ</a>
                        <button type="submit" class="btn btn-primary px-5 shadow fw-bold">Lưu nhân viên</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const fileInput = document.getElementById('fileInput');
        const urlInput = document.getElementById('urlInput');
        const imgPreview = document.getElementById('imgPreview');

        fileInput.addEventListener('change', function () {
            const [file] = this.files;
            if (file) {
                imgPreview.src = URL.createObjectURL(file);
                imgPreview.classList.remove('d-none');
                urlInput.value = "";
            }
        });

        urlInput.addEventListener('input', function () {
            const url = this.value.trim();
            if (url) {
                imgPreview.src = url;
                imgPreview.classList.remove('d-none');
                fileInput.value = "";
            } else {
                imgPreview.src = "#";
                imgPreview.classList.add('d-none');
            }
        });
    </script>
}