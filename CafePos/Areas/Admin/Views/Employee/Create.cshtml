@model CafePos.Models.ViewModels.EmployeeVM
@{
    ViewData["Title"] = "Thêm nhân viên mới";
}

<div class="row justify-content-center py-4">
    <div class="col-md-10 col-lg-8">
        <div class="card shadow-lg border-0 rounded-3">
            <div class="card-header bg-primary text-white py-3 text-center">
                <h4 class="mb-0 fw-bold"><i class="bi bi-person-plus-fill me-2"></i>Thêm Nhân Viên Mới</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <h5 class="text-secondary border-bottom pb-2 mb-3">Thông tin tài khoản</h5>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="Username" class="form-label fw-bold">Tên đăng nhập</label>
                                <input asp-for="Username" class="form-control border-2" placeholder="VD: nhanvien01" />
                                <span asp-validation-for="Username" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="Password" class="form-label fw-bold">Mật khẩu</label>
                                <input asp-for="Password" type="password" class="form-control border-2" placeholder="Nhập mật khẩu" />
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <h5 class="text-secondary border-bottom pb-2 mt-3 mb-3">Thông tin cá nhân</h5>
                    <div class="form-group mb-3">
                        <label asp-for="FullName" class="form-label fw-bold">Họ và tên nhân viên</label>
                        <input asp-for="FullName" class="form-control border-2" placeholder="VD: Nguyễn Văn A" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="EmployeeCode" class="form-label fw-bold">Mã nhân viên (Tùy chọn)</label>
                                <input asp-for="EmployeeCode" class="form-control border-2" placeholder="VD: NV001" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="PhoneNumber" class="form-label fw-bold">Số điện thoại</label>
                                <input asp-for="PhoneNumber" class="form-control border-2" placeholder="VD: 090xxxxxxx" />
                            </div>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Address" class="form-label fw-bold">Địa chỉ</label>
                        <input asp-for="Address" class="form-control border-2" placeholder="Nhập địa chỉ tạm trú" />
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label fw-bold">Ảnh hồ sơ</label>
                        <input type="file" name="file" class="form-control border-2" id="fileInput" accept="image/*" />
                        <input type="hidden" asp-for="ImageUrl" id="urlInput" />
                    </div>

                    <div class="text-center mb-3">
                        <img id="imgPreview" src="#" alt="Xem trước ảnh" class="rounded-circle shadow-sm d-none" style="width: 150px; height: 150px; object-fit: cover; border: 3px solid #eee;" />
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end pt-3">
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">Hủy bỏ</a>
                        <button type="submit" class="btn btn-primary px-5 shadow fw-bold">Lưu nhân viên</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const fileInput = document.getElementById('fileInput');
        const imgPreview = document.getElementById('imgPreview');

        fileInput.addEventListener('change', function() {
            const [file] = this.files;
            if (file) {
                imgPreview.src = URL.createObjectURL(file);
                imgPreview.classList.remove('d-none');
            }
        });
    </script>
}