@model CafePos.Models.ProductSize
@{
    ViewData["Title"] = "Chi tiết size sản phẩm";
    bool isAdmin = User.IsInRole("Admin");
}

<div class="container-fluid py-4">
    <div class="card shadow border-0 rounded-4">
        <div class="card-header bg-info text-white py-3">
            <h5 class="mb-0">
                <i class="bi bi-info-circle me-2"></i>Thông tin size sản phẩm
            </h5>
        </div>

        <div class="card-body p-4">
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="border rounded-4 p-3 bg-light h-100">
                        <h6 class="text-muted mb-3">Thông tin cơ bản</h6>

                        <dl class="row mb-0">
                            <dt class="col-sm-4">Mã size:</dt>
                            <dd class="col-sm-8 fw-semibold text-dark">@Model.ProductSizeId</dd>

                            <dt class="col-sm-4">Tên sản phẩm:</dt>
                            <dd class="col-sm-8 fw-bold text-primary">@Model.Product?.Name</dd>

                            <dt class="col-sm-4">Tên size:</dt>
                            <dd class="col-sm-8">
                                <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill">
                                    <i class="bi bi-tag me-1"></i>@Model.SizeName
                                </span>
                            </dd>

                            <dt class="col-sm-4">Giá cộng thêm:</dt>
                            <dd class="col-sm-8 text-success fw-bold">
                                @Model.ExtraPrice.ToString("N0") VNĐ
                            </dd>
                        </dl>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="border rounded-4 p-3 h-100 bg-white">
                        <h6 class="text-muted mb-3">Ghi chú</h6>
                        <div class="text-muted">
                            Đây là thông tin chi tiết của size sản phẩm trong hệ thống CafePOS.
                            Size này sẽ được dùng khi chọn món trong quá trình bán hàng.
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                @if (isAdmin)
                {
                    <a asp-action="Edit" asp-route-id="@Model.ProductSizeId" class="btn btn-warning">
                        <i class="bi bi-pencil-square me-1"></i> Sửa
                    </a>
                }

                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại
                </a>
            </div>
        </div>
    </div>
</div>