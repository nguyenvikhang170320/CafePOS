@model CafePos.Models.User

@{
    ViewData["Title"] = "Trang cá nhân";
    var errorMessage = TempData["ErrorMessage"] ?? ViewBag.Error;
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h4 class="mb-0"><i class="bi bi-gear-fill me-2"></i> Thông tin cá nhân</h4>
                </div>

                <div class="card-body p-4">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @if (errorMessage != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-x-octagon-fill me-2"></i> @errorMessage
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <div class="mb-4 text-center">
                        <i class="bi bi-person-circle text-primary" style="font-size: 4rem;"></i>
                        <h5 class="mt-2 mb-1">@Model.Username</h5>
                        <span class="badge bg-info p-2 mt-1">Vai trò: @Model.Role?.Name</span>
                    </div>

                    <hr />

                    <form>
                        <input type="hidden" asp-for="UserId" />

                        <div class="row">
                            <div class="col-12 mb-3">
                                <label asp-for="Email" class="form-label fw-bold">
                                    <i class="bi bi-envelope me-2"></i> Email
                                </label>
                                <input asp-for="Email" class="form-control" readonly />
                            </div>

                            <div class="col-12 mb-3">
                                <label asp-for="FullName" class="form-label fw-bold">
                                    <i class="bi bi-telephone me-2"></i> Tên đầy đủ
                                </label>
                                <input asp-for="FullName" class="form-control" readonly />
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}