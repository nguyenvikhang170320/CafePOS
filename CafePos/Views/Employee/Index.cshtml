@model IEnumerable<CafePos.Models.Employee>
@{
    ViewData["Title"] = "Danh sách nhân viên";
    bool isAdmin = User.IsInRole("Admin");
}

<style>
    .custom-card {
        border-radius: 15px;
        overflow: hidden;
        border: none;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05) !important;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(13, 110, 253, 0.05); /* Màu xanh nhạt khi hover */
        transition: 0.3s;
    }

    .btn-action {
        width: 32px;
        height: 32px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        margin-left: 4px;
    }

    .emp-img {
        width: 45px;
        height: 45px;
        object-fit: cover;
        border-radius: 50%; /* Nhân viên để ảnh tròn cho chuyên nghiệp */
        border: 2px solid #fff;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

    .badge-role {
        background: #e7f1ff;
        color: #0d6efd;
        border: 1px solid #cfe2ff;
        padding: 0.4em 0.8em;
        border-radius: 6px;
        font-size: 0.85rem;
    }
</style>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="text-dark fw-bold mb-0">
                <i class="bi bi-people-fill text-primary me-2"></i>Quản lý nhân sự
            </h3>
            <p class="text-muted small mb-0">Điều hành danh sách và quyền hạn nhân viên</p>
        </div>

        <div class="d-flex gap-2">
            @if (isAdmin)
            {
                <a asp-action="Trash" class="btn btn-outline-secondary px-3 shadow-sm border-0 bg-white text-danger">
                    <i class="bi bi-person-x me-1"></i> Thùng rác
                </a>
                <a asp-action="Create" class="btn btn-primary px-3 shadow-sm fw-bold">
                    <i class="bi bi-person-plus-fill me-1"></i> Thêm nhân viên
                </a>
            }
        </div>
    </div>

    <div class="card custom-card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3" style="width: 60px;">STT</th>
                            <th style="width: 80px;">Ảnh</th>
                            <th>Họ và Tên</th>
                            <th>Mã NV</th>
                            <th>Tài khoản</th>
                            <th>Số điện thoại</th>
                            <th class="text-end pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 text-muted">@item.EmployeeId</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" class="emp-img" alt="@item.User.FullName" />
                                    }
                                    else
                                    {
                                        <div class="emp-img bg-light d-flex align-items-center justify-content-center text-muted border">
                                            <i class="bi bi-person small"></i>
                                        </div>
                                    }
                                </td>
                                <td>
                                    <div class="fw-bold text-dark">@item.User.FullName</div>
                                    <span class="text-muted small">Vào làm: @item.HireDate.ToString("dd/MM/yyyy")</span>
                                </td>
                                <td>
                                    <span class="text-secondary font-monospace">@item.EmployeeCode</span>
                                </td>
                                <td>
                                    <span class="badge-role">
                                        <i class="bi bi-person-badge me-1 small"></i> @item.User.Username
                                    </span>
                                </td>
                                <td class="text-dark">
                                    @(item.PhoneNumber ?? "---")
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end">
                                        <a asp-action="Detail" asp-route-id="@item.EmployeeId"
                                           class="btn btn-action btn-outline-info" title="Xem hồ sơ">
                                            <i class="bi bi-file-earmark-person"></i>
                                        </a>

                                        @if (isAdmin)
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.EmployeeId"
                                               class="btn btn-action btn-outline-warning" title="Sửa">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>

                                            <form asp-action="Delete" asp-route-id="@item.UserId" method="post"
                                                  class="d-inline" onsubmit="return confirm('Bạn có chắc muốn cho nhân viên này nghỉ việc?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-action btn-outline-danger" title="Cho nghỉ việc">
                                                    <i class="bi bi-person-dash"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>