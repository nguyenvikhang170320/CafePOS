@model CafePos.Models.Category
@{
    ViewData["Title"] = "Chi tiết danh mục";
}

<div class="container-fluid">
    <div class="card shadow border-0">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0"><i class="bi bi-info-circle"></i> Thông tin danh mục: @Model.Name</h5>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Tên danh mục:</dt>
                <dd class="col-sm-9 fw-bold text-primary">@Model.Name</dd>

                <dt class="col-sm-3">Số lượng sản phẩm:</dt>
                <dd class="col-sm-9">@(Model.Products?.Count() ?? 0) món</dd>
            </dl>

            <h5 class="mt-4">Danh sách món nước thuộc loại này:</h5>
            <ul class="list-group mb-3">
                @if (Model.Products != null && Model.Products.Any())
                {
                    foreach (var p in Model.Products)
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            <span>@p.Name</span>
                            <span class="text-success">@p.BasePrice.ToString("N0") VNĐ</span>
                        </li>
                    }
                }
                else
                {
                    <li class="list-group-item text-muted">Chưa có món nào trong danh mục này.</li>
                }
            </ul>

            <div class="mt-3">
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Edit" asp-route-id="@Model.CategoryId" class="btn btn-warning"><i class="bi bi-pencil"></i> Sửa</a>
                }
                <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
            </div>
        </div>
    </div>
</div>