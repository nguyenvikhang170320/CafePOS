@model IEnumerable<CafePos.Models.Category>
@{
    ViewData["Title"] = "Danh mục món ăn";
    bool isAdmin = User.IsInRole("Admin");
}

<style>
    /* Bo góc và hiệu ứng đổ bóng mượt hơn cho Card */
    .custom-card {
        border-radius: 15px;
        overflow: hidden;
        border: none;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05) !important;
    }

    /* Hiệu ứng Hover dòng trong bảng */
    .table-hover tbody tr:hover {
        background-color: rgba(255, 193, 7, 0.05); /* Màu vàng nhạt khi hover */
        transition: 0.3s;
    }

    /* Tùy chỉnh các nút bấm icon tròn hơn */
    .btn-action {
        width: 35px;
        height: 35px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        margin-left: 5px;
    }

    /* Huy hiệu số lượng món */
    .badge-count {
        background: #e3f2fd;
        color: #0d6efd;
        font-weight: 600;
        padding: 0.5em 1em;
        border-radius: 8px;
    }
</style>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="text-dark fw-bold mb-0">
                <i class="bi bi-collection-play-fill text-warning me-2"></i>Danh mục thực đơn
            </h3>
            <p class="text-muted small mb-0">Quản lý các nhóm món ăn trong hệ thống</p>
        </div>

        <div class="d-flex gap-2">
            @if (isAdmin)
            {
                <a asp-action="Trash" class="btn btn-outline-secondary px-3 shadow-sm border-0 bg-white">
                    <i class="bi bi-trash3 me-1"></i> Thùng rác
                </a>
                <a asp-action="Create" class="btn btn-primary px-3 shadow-sm fw-bold">
                    <i class="bi bi-plus-lg me-1"></i> Thêm mới
                </a>
            }
        </div>
    </div>

    <div class="card custom-card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 text-secondary py-3" style="width: 80px;">STT</th>
                            <th class="text-secondary py-3">Tên danh mục</th>
                            <th class="text-center text-secondary py-3">Quy mô</th>
                            <th class="text-end pe-4 text-secondary py-3">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                       
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 text-muted">@item.CategoryId</td>
                                <td>
                                    <span class="fw-bold text-dark fs-6">@item.Name</span>
                                </td>
                                <td class="text-center">
                                    <span class="badge-count">
                                        <i class="bi bi-cup-hot me-1"></i>
                                        @* Đếm số lượng sản phẩm trong danh sách đã được Include *@
                                        @(item.Products?.Count() ?? 0) món
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end">
                                        <a asp-action="Detail" asp-route-id="@item.CategoryId"
                                           class="btn btn-action btn-outline-info" title="Xem chi tiết">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        @if (isAdmin)
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.CategoryId"
                                               class="btn btn-action btn-outline-warning" title="Chỉnh sửa">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>

                                            <form asp-action="Delete" asp-route-id="@item.CategoryId" method="post"
                                                  class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn ẩn danh mục này?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-action btn-outline-danger" title="Xóa mềm">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>