<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cafe POS</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        .navbar-nav .nav-link {
            white-space: nowrap;
            padding-left: 0.9rem;
            padding-right: 0.9rem;
        }

            .navbar-nav .nav-link.active {
                color: #ffc107 !important;
                font-weight: 700;
                border-bottom: 2px solid #ffc107;
            }

        .dropdown-menu {
            border: 0;
            border-radius: 0.75rem;
        }

        .dropdown-item.active,
        .dropdown-item:active {
            background-color: #0d6efd;
        }

        .navbar-brand {
            letter-spacing: .3px;
        }

        body {
            background: #f8f9fa;
        }
    </style>
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
    }

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    ☕ HỆ THỐNG CAFE
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Home" ? "active" : "")"
                               asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-1"></i>Tổng quan
                            </a>
                        </li>

                        @* STAFF: khách hàng *@
                        @if (User.IsInRole("Staff"))
                        {
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "CustomerOrder" && currentAction == "Create" ? "active" : "")"
                                   asp-controller="CustomerOrder" asp-action="Create">
                                    <i class="bi bi-basket me-1"></i>Đặt món
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link @(currentController == "CustomerOrder" && currentAction == "MyOrders" ? "active" : "")"
                                   asp-controller="CustomerOrder" asp-action="MyOrders">
                                    <i class="bi bi-receipt me-1"></i>Đơn của tôi
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link @(currentController == "CustomerOrder" && currentAction == "Invoice" ? "active" : "")"
                                   asp-controller="CustomerOrder" asp-action="Invoice">
                                    <i class="bi bi-file-earmark-text me-1"></i>Hóa đơn của tôi
                                </a>
                            </li>
                        }

                        @* EMPLOYEE: nhân viên quán *@
                        @if (User.IsInRole("Employee"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle @(currentController == "Order" ? "active" : "")"
                                   href="#" id="ordersDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-list-check me-1"></i>Quản lý
                                </a>
                                <ul class="dropdown-menu shadow-sm" aria-labelledby="ordersDropdown">
                                    <li>
                                        <a class="dropdown-item @(currentController == "Order" && currentAction == "Index" ? "active" : "")"
                                            asp-controller="Order" asp-action="Index">
                                            Xử lý đơn hàng
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item @(currentController == "Order" && currentAction == "Invoice" ? "active" : "")"
                                            asp-controller="Order" asp-action="Invoice">
                                            Hóa đơn
                                        </a>
                                    </li>
                                    
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Employee" asp-action="Index">
                                            Danh sách nhân viên
                                        </a>
                                    </li>
                                </ul>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Product" ? "active" : "")"
                                   asp-controller="Product" asp-action="Index">
                                    <i class="bi bi-cup-hot me-1"></i>Sản phẩm
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Category" ? "active" : "")"
                                   asp-controller="Category" asp-action="Index">
                                    <i class="bi bi-tags me-1"></i>Danh mục
                                </a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            var fullName = User.FindFirst("FullName")?.Value ?? User.Identity.Name;

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-warning fw-bold"
                                   href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    👋 Xin chào, @fullName
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow-sm" aria-labelledby="userDropdown">
                                    <li>
                                        <a class="dropdown-item" asp-controller="TaiKhoan" asp-action="Index">
                                            Thông tin tài khoản
                                        </a>     
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item text-danger fw-bold" asp-controller="Account" asp-action="Logout">
                                            <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Account" && currentAction == "Login" ? "active" : "")"
                                   asp-controller="Account" asp-action="Login">
                                    Đăng nhập
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container py-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted text-center py-4 mt-5 bg-white shadow-sm">
        <div class="container">
            &copy; 2026 - Phần mềm quản lý Cafe POS
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/sweetalert2/sweetalert2.all.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var message = '@Html.Raw(TempData["Message"] ?? "")';
            var type = '@(TempData["MessageType"] ?? "")';

            if (message) {
                Swal.fire({
                    title: 'Thông báo',
                    text: message,
                    icon: type || 'success',
                    timer: 3000,
                    showConfirmButton: false,
                    toast: true,
                    position: 'top-end'
                });
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>