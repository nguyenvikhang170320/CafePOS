@model IEnumerable<CafePos.Models.Topping>
@{
    ViewData["Title"] = "Danh sách topping";
    bool isAdmin = User.IsInRole("Admin");
    int i = 1;
}

<style>
    .custom-card {
        border-radius: 15px;
        overflow: hidden;
        border: none;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05) !important;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(255, 193, 7, 0.05);
        transition: 0.3s;
    }

    .btn-action {
        width: 35px;
        height: 35px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        margin-left: 5px;
    }

    .badge-count {
        background: #e3f2fd;
        color: #0d6efd;
        font-weight: 600;
        padding: 0.5em 1em;
        border-radius: 8px;
    }

    .badge-status-active {
        background: #e8f5e9;
        color: #198754;
        font-weight: 600;
        padding: 0.5em 1em;
        border-radius: 8px;
    }

    .badge-status-inactive {
        background: #fff3cd;
        color: #856404;
        font-weight: 600;
        padding: 0.5em 1em;
        border-radius: 8px;
    }
</style>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="text-dark fw-bold mb-0">
                <i class="bi bi-cup-straw text-warning me-2"></i>Danh sách topping
            </h3>
            <p class="text-muted small mb-0">Quản lý topping trong hệ thống CafePOS</p>
        </div>

    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card custom-card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 text-secondary py-3" style="width: 80px;">STT</th>
                            <th class="text-secondary py-3">Tên topping</th>
                            <th class="text-center text-secondary py-3">Giá</th>
                            <th class="text-center text-secondary py-3">Trạng thái</th>
                            <th class="text-end pe-4 text-secondary py-3">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 text-muted">@item.ToppingId.ToString("D2")</td>

                                    <td>
                                        <span class="fw-bold text-dark fs-6">@item.Name</span>
                                    </td>

                                    <td class="text-center">
                                        <span class="badge-count">
                                            <i class="bi bi-cash-coin me-1"></i>
                                            @item.Price.ToString("N0") đ
                                        </span>
                                    </td>

                                    <td class="text-center">
                                        @if (item.IsActive)
                                        {
                                            <span class="badge-status-active">
                                                <i class="bi bi-check-circle me-1"></i>Đang áp dụng
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge-status-inactive">
                                                <i class="bi bi-pause-circle me-1"></i>Ngưng áp dụng
                                            </span>
                                        }
                                    </td>

                                    <td class="text-end pe-4">
                                        <div class="d-flex justify-content-end">
                                            <a asp-action="Detail" asp-route-id="@item.ToppingId"
                                               class="btn btn-action btn-outline-info" title="Xem chi tiết">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                              
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">
                                    <i class="bi bi-inboxes fs-4 d-block mb-2"></i>
                                    Chưa có topping nào trong danh sách.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>