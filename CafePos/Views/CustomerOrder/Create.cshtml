@using CafePos.Models
@{
    ViewData["Title"] = "Đặt món";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var products = ViewBag.Products as List<Product>;
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h2 class="fw-bold mb-2">Đặt món</h2>
                    <p class="text-muted mb-4">Chọn món và nhập thông tin khách hàng để gửi đơn.</p>

                    <form asp-action="Create" method="post" id="orderForm">
                        @Html.AntiForgeryToken()

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label">Tên khách hàng</label>
                                <input type="text" name="customerName" class="form-control" required />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Số điện thoại</label>
                                <input type="text" name="customerPhone" class="form-control" required />
                            </div>

                            <div class="col-12">
                                <label class="form-label">Ghi chú</label>
                                <textarea name="note" class="form-control" rows="3" placeholder="Ví dụ: ít đá, ít ngọt..."></textarea>
                            </div>
                        </div>

                        <h5 class="fw-bold mb-3">Chọn món</h5>

                        <div class="table-responsive">
                            <table class="table table-bordered align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Tên món</th>
                                        <th>Giá</th>
                                        <th>Số lượng</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (products != null && products.Any())
                                    {
                                        for (int i = 0; i < products.Count; i++)
                                        {
                                            <tr>
                                                <td>
                                                    @products[i].Name
                                                    <input type="hidden" name="productIds" value="@products[i].ProductId" />
                                                </td>
                                                <td class="text-danger fw-bold">@products[i].BasePrice.ToString("N0") đ</td>
                                                <td style="width: 160px;">
                                                    <input type="number"
                                                           name="quantities"
                                                           class="form-control quantity-input"
                                                           min="0"
                                                           value="0" />
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="3" class="text-center text-muted py-4">
                                                Không có sản phẩm nào.
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="alert alert-danger d-none mt-3" id="quantityError">
                            Vui lòng chọn ít nhất 1 món và nhập số lượng lớn hơn 0.
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary rounded-pill px-4">
                                Gửi đơn
                            </button>
                            <a asp-action="MyOrders" class="btn btn-outline-secondary rounded-pill px-4">
                                Đơn của tôi
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const form = document.getElementById("orderForm");
            const quantityInputs = document.querySelectorAll(".quantity-input");
            const quantityError = document.getElementById("quantityError");

            form.addEventListener("submit", function (e) {
                let hasValidItem = false;

                quantityInputs.forEach(input => {
                    const value = parseInt(input.value || "0");
                    if (value > 0) {
                        hasValidItem = true;
                    }
                });

                if (!hasValidItem) {
                    e.preventDefault();
                    quantityError.classList.remove("d-none");
                    quantityError.scrollIntoView({ behavior: "smooth", block: "center" });
                    return;
                }

                quantityError.classList.add("d-none");
            });
        });
    </script>
}