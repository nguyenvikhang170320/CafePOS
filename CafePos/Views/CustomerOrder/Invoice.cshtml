@model IEnumerable<Order>

@{
    ViewData["Title"] = "Hóa đơn của tôi";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1">Hóa đơn của tôi</h3>
            <p class="text-muted mb-0">Chọn hóa đơn để xem chi tiết</p>
        </div>
        <a asp-action="MyOrders" asp-route-phone="@ViewBag.Phone" class="btn btn-outline-secondary rounded-pill px-4">
            Quay lại đơn của tôi
        </a>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="list-group list-group-flush" style="max-height: 70vh; overflow-y: auto;">
                    @foreach (var item in Model)
                    {
                        <button type="button"
                                class="list-group-item list-group-item-action customer-invoice-item"
                                data-id="@item.OrderId">
                            <div class="fw-bold">@item.OrderCode</div>
                            <small>@item.CreatedDate.ToString("dd/MM/yyyy HH:mm")</small>
                            <div class="text-danger fw-semibold">@item.TotalAmount.ToString("N0") đ</div>
                        </button>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div id="customerInvoiceDetail">
                <div class="alert alert-info rounded-4">Vui lòng chọn hóa đơn để xem chi tiết.</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $(".customer-invoice-item").click(function () {
                let id = $(this).data("id");

                $("#customerInvoiceDetail").html("<div class='text-center p-4'>Đang tải hóa đơn...</div>");

                $.ajax({
                    url: '@Url.Action("GetInvoicePartial", "CustomerOrder")',
                    type: 'GET',
                    data: { id: id },
                    success: function (res) {
                        $("#customerInvoiceDetail").html(res);
                    },
                    error: function () {
                        $("#customerInvoiceDetail").html("<div class='alert alert-danger rounded-4'>Lỗi tải hóa đơn.</div>");
                    }
                });
            });
        });
    </script>
}